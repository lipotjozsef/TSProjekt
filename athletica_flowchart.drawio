        <mxCell id="MTkbwlnuCuaM9ma4jEXN-29" parent="1" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=middle;rounded=0;" value="&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div&gt;/src&lt;/div&gt;&lt;div&gt;├───/api&lt;/div&gt;&lt;div&gt;│&amp;nbsp; &amp;nbsp;└───/APIErrors&lt;/div&gt;&lt;div&gt;│&amp;nbsp; &amp;nbsp;└───http.service.ts&lt;/div&gt;&lt;div&gt;├───/assets&lt;/div&gt;&lt;div&gt;│&amp;nbsp; &amp;nbsp;├───/images&lt;/div&gt;&lt;div&gt;│&amp;nbsp; &amp;nbsp;└───/JSONData&lt;/div&gt;&lt;div&gt;├───/storage&lt;/div&gt;&lt;div&gt;│&amp;nbsp; &amp;nbsp;└───tablemanager.service.ts&lt;/div&gt;&lt;div&gt;│&amp;nbsp; &amp;nbsp;└───tabmanager.service.ts&lt;/div&gt;&lt;div&gt;├───/styles&lt;/div&gt;&lt;div&gt;├───/types&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 102, 102));&quot;&gt;└───/views&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; &lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 102, 102));&quot;&gt;├───/main&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 102, 102));&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ├───main.ts&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 102, 102));&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; └───main.html&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 102, 102));&quot;&gt;&amp;nbsp; &amp;nbsp; └───/tables&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 102, 102));&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ├───tables.ts&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 102, 102));&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; └───tables.html&lt;/font&gt;&lt;/div&gt;&lt;/blockquote&gt;" vertex="1">
